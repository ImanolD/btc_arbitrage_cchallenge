# ── Server ───────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of exchanges to enable (must match connector ids).
# Available: binance, kraken, okx, bybit, kucoin, gate (USDT-quoted);
#            bitstamp, bitfinex (USD-quoted — grouped separately by the engine).
EXCHANGES=binance,kraken,okx,bybit,kucoin,gate,bitstamp,bitfinex
# Trading symbol to monitor (USD-native venues automatically use the USD pair)
SYMBOL=BTCUSDT

# Venues to run single-exchange triangular arbitrage on (each needs BTC/USDT,
# ETH/BTC and ETH/USDT). Independent of the cross-exchange list above.
TRIANGULAR_EXCHANGES=binance,okx,bybit,kucoin,gate
# Notional (quote currency) used to size each triangular loop
TRIANGULAR_NOTIONAL_USD=10000

# ── Engine ───────────────────────────────────────────────────────────────
# Notional cap per simulated arbitrage leg, in quote currency (USDT)
MAX_NOTIONAL_USD=50000
# Minimum net profit (in quote currency) required to fire a trade
MIN_NET_PROFIT_USD=1
# Reject spreads wider than this fraction (data-glitch guard), e.g. 0.05 = 5%
MAX_SANE_SPREAD_PCT=0.05
# Ignore a quote older than this many milliseconds (stale-feed guard)
MAX_QUOTE_AGE_MS=2000

# Start with the clearly-labeled demo/replay injector ON (also toggleable live
# from the dashboard). Injects synthetic price dislocations to demonstrate the
# full execution path. Leave false for honest live monitoring.
DEMO_MODE=false

# ── Starting simulated balances (per exchange) ───────────────────────────
START_USD_PER_EXCHANGE=100000
START_BTC_PER_EXCHANGE=2
# Inventory drift (BTC) a venue may accumulate before an on-chain rebalance is
# triggered. The withdrawal fee paid then is amortized across trades — the only
# place withdrawal costs enter the model.
REBALANCE_THRESHOLD_BTC=0.5

# ── Expected-value model (decide by EV, not by a raw spread threshold) ────
# Survival ≈ exp(-age/EV_TAU_MS) · edgeConfidence · liquiditySupport
EV_TAU_MS=400
# Adverse-selection cost (bps of notional) charged if the edge collapses
EV_ADVERSE_BPS=5
# Minimum expected value (quote currency) required to fire a trade
EV_MIN_USD=0
# Decision rule: "ev" (expected value, default) or "spread" (naive net-spread
# threshold). Also switchable live from the dashboard Settings panel.
DECISION_MODE=ev

# ── Filo chat (optional LLM layer) ───────────────────────────────────────
# Filo answers questions deterministically (grounded, instant) out of the box.
# Set an Anthropic key to also handle free-form questions via Claude; if unset
# or the call fails, Filo gracefully falls back to its deterministic answers.
# ANTHROPIC_API_KEY=sk-ant-...
# Model used for free-form answers (small + fast by default).
FILO_MODEL=claude-3-5-haiku-latest
# Period (ms) of Filo's unprompted session digest; 0 disables it. Live-tunable
# from the dashboard Settings panel.
FILO_DIGEST_MS=75000
# Whether Filo posts unprompted narrations at all ("false" mutes them; answers
# to questions are unaffected). Live-tunable from Settings.
FILO_NARRATE=true

# ── Web ──────────────────────────────────────────────────────────────────
# Used by apps/web at build time (Vite). Points to the server origin.
VITE_SERVER_URL=http://localhost:4000
